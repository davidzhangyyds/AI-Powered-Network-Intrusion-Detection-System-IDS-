# =============================================================================
# .dockerignore — kept tight so the build context stays under 5 MB.
# =============================================================================

# -----------------------------------------------------------------------------
# Python virtual environments / caches (anywhere in the tree)
# -----------------------------------------------------------------------------
**/venv/
**/.venv/
**/env/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# -----------------------------------------------------------------------------
# Git / VCS
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/

# -----------------------------------------------------------------------------
# IDE / editor metadata
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# -----------------------------------------------------------------------------
# Notebooks (not used at runtime)
# -----------------------------------------------------------------------------
notebooks/
**/*.ipynb
**/.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Raw datasets — too big and not needed at inference time
# -----------------------------------------------------------------------------
data/
**/*.csv

# -----------------------------------------------------------------------------
# MLflow artefact directories + nested duplicates inside src/
# (We DO copy the top-level mlflow.db; that's hand-listed in the Dockerfile.)
# -----------------------------------------------------------------------------
mlruns/
src/mlruns/
src/mlflow.db
src/mlflow_tracking.db
src/models/
mlflow_tracking.db

# -----------------------------------------------------------------------------
# Backup / temp / log files
# -----------------------------------------------------------------------------
*.bak
*.log
*.tmp
test_write.txt
requirements.txt.bak

# -----------------------------------------------------------------------------
# Secrets / env (not used in the image, but never let them leak in)
# -----------------------------------------------------------------------------
.env
.env.*

# -----------------------------------------------------------------------------
# Docker artefacts themselves (not needed inside the image)
# -----------------------------------------------------------------------------
Dockerfile
.dockerignore
docker-compose.yml

# -----------------------------------------------------------------------------
# Project meta files not needed at runtime
# -----------------------------------------------------------------------------
README.md
LICENSE

# -----------------------------------------------------------------------------
# Source files NOT used by the Gradio frontend (keeps the image lean)
# -----------------------------------------------------------------------------
src/app.py
src/train.py
src/train_phi.py
src/eda.py
src/data_splitting.py
src/test_knn.py